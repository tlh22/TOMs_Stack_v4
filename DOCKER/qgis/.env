# ===============================================================================
# QGIS version selector for TOMs Docker setup.
# Uncomment ONE block at a time, then run:
#   docker compose build --no-cache && docker compose up -d
#
# -- How to add a future version -----------------------------------------------
# Add a new block below. Set all five variables. No Dockerfile changes needed.
#
# QGIS_REPO_TYPE values:
#   builtin      -> version ships in BASE_IMAGE apt repos (no extra repo)
#   backports    -> Debian backports (needs QGIS_SUITE)
#   qgis-org     -> qgis.org/debian or qgis.org/ubuntu repo (needs QGIS_SUITE)
#   qgis-nightly -> qgis.org nightly (needs QGIS_SUITE)
#   preinstalled -> QGIS already inside BASE_IMAGE (e.g. qgis/qgis:final-*)
#
# QGIS_QT: set to 5 or 6 -- controls which Qt library packages are installed.
# ===============================================================================
# -- QGIS 3.22 LTS (Debian bookworm built-in) ----------------------------------
# QGIS_VERSION=3.22
# BASE_IMAGE=debian:bookworm-slim
# QGIS_PROFILE=qgis_3_22
# QGIS_REPO_TYPE=builtin
# QGIS_SUITE=bookworm
# QGIS_QT=5
# -- QGIS 3.28 LTS (official qgis/qgis Docker image) --------------------------
# This is the only viable option for 3.28 -- no Debian/Ubuntu repo carries it.
# The official image has QGIS + xvfb already installed. We add VNC on top.
#QGIS_VERSION=3.28
#BASE_IMAGE=qgis/qgis:final-3_28_13
#QGIS_PROFILE=qgis_3_28
#QGIS_REPO_TYPE=preinstalled
#QGIS_SUITE=focal
#QGIS_QT=5
# -- QGIS 3.34 LTS (Debian bookworm-backports) ---------------------------------
#QGIS_VERSION=3.34
#BASE_IMAGE=debian:bookworm-slim
#QGIS_PROFILE=qgis_3_34
#QGIS_REPO_TYPE=backports
#QGIS_SUITE=bookworm
#QGIS_QT=5
# -- QGIS 3.40 (Debian bookworm-backports) -------------------------------------
# QGIS_VERSION=3.40
# BASE_IMAGE=debian:bookworm-slim
# QGIS_PROFILE=qgis_3_40
# QGIS_REPO_TYPE=backports
# QGIS_SUITE=bookworm
# QGIS_QT=5
# -- QGIS 3.44 LTS latest (qgis.org/debian bookworm) --------------------------
QGIS_VERSION=3.44
BASE_IMAGE=debian:bookworm-slim
QGIS_PROFILE=qgis_3_44
QGIS_REPO_TYPE=qgis-org
QGIS_SUITE=bookworm
QGIS_QT=5
# -- QGIS 4.0 nightly (qgis.org/debian-nightly-release trixie) ----------------
#QGIS_VERSION=4.0-nightly
#BASE_IMAGE=debian:trixie-slim
#QGIS_PROFILE=qgis_4_0
#QGIS_REPO_TYPE=qgis-nightly
#QGIS_SUITE=trixie
#QGIS_QT=6

# ── Per-user isolation ─────────────────────────────────────────────────────────
# TOMS_USER   : OS username of the person running this instance.
#               Used in the container name, image tag, and host volume paths.
#               Default: the current OS username ($(whoami) equivalent).
#               Each user MUST set this to their own username so their
#               container and volumes are isolated from all other users.
#
# PORT_BASE   : Integer offset added to the default ports.
#               noVNC host port = 6080 + PORT_BASE
#               VNC   host port = 5900 + PORT_BASE
#               Each user MUST choose a unique PORT_BASE so their ports do
#               not clash with any other running container on this host.
#
#               Suggested assignment (co-ordinate with your team):
#                 alice  PORT_BASE=0    -> noVNC 6080, VNC 5900
#                 bob    PORT_BASE=100  -> noVNC 6180, VNC 6000
#                 carol  PORT_BASE=200  -> noVNC 6280, VNC 6100
#                 dave   PORT_BASE=300  -> noVNC 6380, VNC 6200
#               (Gap of 100 leaves room for future extra services per user.)
#
# TOMS_HOST_BASE : Root directory on the HOST under which per-user runtime
#                  dirs are created automatically by docker compose.
#                  Default: /home/${TOMS_USER}  (standard Linux home).
#                  Override if your users' homes are elsewhere, e.g.:
#                    TOMS_HOST_BASE=/data/users/${TOMS_USER}
# ──────────────────────────────────────────────────────────────────────────────
TOMS_USER=sajid
PORT_BASE=0
TOMS_HOST_BASE=/home/${TOMS_USER}

# -- Shared settings (same on Windows, Mac, and Linux) ------------------------
DISPLAY=:0
USE_VNC=0
UID=1000
GID=1000