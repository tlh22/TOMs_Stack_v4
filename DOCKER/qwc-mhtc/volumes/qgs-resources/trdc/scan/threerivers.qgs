          <rule label="No Waiting (with time restriction)" key="{b3760d70-ecf9-44f6-bcef-d1caa7332a01}" symbol="0" filter=" &quot;RestrictionTypeID&quot; IN (201, 221, 224)"/>
          <rule label="No Waiting At Any Time" key="{84c5afb5-98ac-49a6-8b30-53af37b0bbb4}" symbol="1" filter=" &quot;RestrictionTypeID&quot; IN (202)"/>
          <rule label="Crossing (Zig Zag)" key="{211bbcf7-3777-464a-a6fb-73d4cff7f601}" symbol="2" filter="&quot;RestrictionTypeID&quot; IN (209, 210, 211, 212, 212, 213, 214, 215) AND  &quot;GeomShapeID&quot; = 12"/>
          <rule label="Crossing Point" key="{93f0ced3-3979-4f1f-9031-c0377268d145}" symbol="3" filter=" &quot;RestrictionTypeID&quot; IN (209, 210, 211, 212, 212, 213, 214, 215) AND  &quot;GeomShapeID&quot; != 12"/>
          <rule label="Keep Clear (Zig Zag)" key="{9a7e92c7-fdb8-4979-86b6-7dcdd0c697ff}" symbol="4" filter="&quot;RestrictionTypeID&quot; IN (203, 204, 205, 206, 207, 208)"/>
          <rule label="No Loading At Any Time" key="{a87ad0c1-f991-4da2-a424-00bc4a9bbf15}" symbol="5" filter="&quot;NoLoadingTimeID&quot; = 1 AND &quot;RestrictionTypeID&quot; IN (201, 202, 221, 224)"/>
          <rule label="No Loading with Restriction Hours" key="{8d210bf4-9f43-45ca-ae66-c47c8e27bcaf}" symbol="6" filter=" &quot;NoLoadingTimeID&quot; > 1 AND  &quot;RestrictionTypeID&quot; IN (201, 202, 221, 224) "/>
