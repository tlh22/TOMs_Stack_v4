<schema xmlns:ogc="http://www.opengis.net/ogc" xmlns:qgs="http://www.qgis.org/gml" elementFormDefault="qualified" version="1.0" xmlns:gml="http://www.opengis.net/gml" xmlns="http://www.w3.org/2001/XMLSchema" xmlns:xsd="http://www.w3.org/2001/XMLSchema" targetNamespace="http://www.qgis.org/gml">
 <import namespace="http://www.opengis.net/gml" schemaLocation="http://schemas.opengis.net/gml/3.1.1/base/gml.xsd"/>
 <element name="RestrictionPolygons" type="qgs:RestrictionPolygonsType" substitutionGroup="gml:_Feature"/>
 <complexType name="RestrictionPolygonsType">
  <complexContent>
   <extension base="gml:AbstractFeatureType">
    <sequence>
     <element name="geometry" type="gml:PolygonPropertyType" maxOccurs="1" minOccurs="0"/>
     <element name="RestrictionTypeID" type="int"/>
     <element name="NoWaitingTimeID" type="int" nillable="true"/>
     <element name="NoLoadingTimeID" type="int" nillable="true"/>
     <element name="TimePeriodID" type="int" nillable="true"/>
     <element name="AreaPermitCode" type="string" nillable="true"/>
     <element name="AdditionalConditionID" type="int" nillable="true"/>
     <element name="DisplayLabel" type="boolean"/>
    </sequence>
   </extension>
  </complexContent>
 </complexType>
 <element name="StreetGazetteerRecords" type="qgs:StreetGazetteerRecordsType" substitutionGroup="gml:_Feature"/>
 <complexType name="StreetGazetteerRecordsType">
  <complexContent>
   <extension base="gml:AbstractFeatureType">
    <sequence>
     <element name="geometry" type="gml:MultiCurvePropertyType" maxOccurs="1" minOccurs="0"/>
     <element name="gid" type="int"/>
     <element name="ASSET_ID" type="string" nillable="true"/>
     <element name="FEATURE_ID" type="string" nillable="true"/>
     <element name="SITE_CODE" type="string" nillable="true"/>
     <element name="SITE_NAME" type="string" nillable="true"/>
     <element name="LOCALITY" type="string" nillable="true"/>
     <element name="TOWN" type="string" nillable="true"/>
     <element name="LOCATION" type="string" nillable="true"/>
     <element name="ROADCLASS" type="string" nillable="true"/>
     <element name="HIERARCHY" type="string" nillable="true"/>
     <element name="CUSTOMER" type="string" nillable="true"/>
     <element name="AREA_NAME" type="string" nillable="true"/>
     <element name="DISTANCE" type="decimal" nillable="true"/>
     <element name="ROAD_TYPE" type="string" nillable="true"/>
    </sequence>
   </extension>
  </complexContent>
 </complexType>
</schema>
