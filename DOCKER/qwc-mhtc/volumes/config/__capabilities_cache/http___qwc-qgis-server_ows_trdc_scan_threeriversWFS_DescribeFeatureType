<schema xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns="http://www.w3.org/2001/XMLSchema" version="1.0" xmlns:qgs="http://www.qgis.org/gml" elementFormDefault="qualified" xmlns:ogc="http://www.opengis.net/ogc" targetNamespace="http://www.qgis.org/gml" xmlns:gml="http://www.opengis.net/gml">
 <import namespace="http://www.opengis.net/gml" schemaLocation="http://schemas.opengis.net/gml/3.1.1/base/gml.xsd"/>
 <element type="qgs:RestrictionPolygonsType" substitutionGroup="gml:_Feature" name="RestrictionPolygons"/>
 <complexType name="RestrictionPolygonsType">
  <complexContent>
   <extension base="gml:AbstractFeatureType">
    <sequence>
     <element maxOccurs="1" type="gml:PolygonPropertyType" name="geometry" minOccurs="0"/>
     <element type="int" name="RestrictionTypeID"/>
     <element type="int" nillable="true" name="NoWaitingTimeID"/>
     <element type="int" nillable="true" name="NoLoadingTimeID"/>
     <element type="int" nillable="true" name="TimePeriodID"/>
     <element type="string" nillable="true" name="AreaPermitCode"/>
     <element type="int" nillable="true" name="AdditionalConditionID"/>
     <element type="boolean" name="DisplayLabel"/>
    </sequence>
   </extension>
  </complexContent>
 </complexType>
 <element type="qgs:StreetGazetteerRecordsType" substitutionGroup="gml:_Feature" name="StreetGazetteerRecords"/>
 <complexType name="StreetGazetteerRecordsType">
  <complexContent>
   <extension base="gml:AbstractFeatureType">
    <sequence>
     <element maxOccurs="1" type="gml:MultiCurvePropertyType" name="geometry" minOccurs="0"/>
     <element type="int" name="gid"/>
     <element type="string" nillable="true" name="ASSET_ID"/>
     <element type="string" nillable="true" name="FEATURE_ID"/>
     <element type="string" nillable="true" name="SITE_CODE"/>
     <element type="string" nillable="true" name="SITE_NAME"/>
     <element type="string" nillable="true" name="LOCALITY"/>
     <element type="string" nillable="true" name="TOWN"/>
     <element type="string" nillable="true" name="LOCATION"/>
     <element type="string" nillable="true" name="ROADCLASS"/>
     <element type="string" nillable="true" name="HIERARCHY"/>
     <element type="string" nillable="true" name="CUSTOMER"/>
     <element type="string" nillable="true" name="AREA_NAME"/>
     <element type="decimal" nillable="true" name="DISTANCE"/>
     <element type="string" nillable="true" name="ROAD_TYPE"/>
    </sequence>
   </extension>
  </complexContent>
 </complexType>
</schema>
