{
  "$schema": "https://github.com/qwc-services/qwc-fulltext-search-service/raw/2024-lts/schemas/qwc-search-service.json",
  "service": "search",
  "config": {
    "solr_service_url": "http://qwc-solr:8983/solr/gdi/select",
    "search_result_limit": 15,
    "db_url": "postgresql:///?service=threerivers"
  },
  "resources": {
    "facets": [
      {
        "name": "trdc_road_name",
        "filter_word": "trdc_road_name",
        "table_name": "local_authority.StreetGazetteerRecords_with_postcode",
        "geometry_column": "geom",
        "search_id_col": "gid",
        "display_field": "\"SITE_NAME\" || ', ' || \"TOWN\" || ' (' || postcode || ')'"
      },
      {
        "name": "trdc_postcode",
        "filter_word": "trdc_postcode",
        "table_name": "local_authority.CodePoint_Open_TRDC_with_street",
        "geometry_column": "geom",
        "search_id_col": "id",
        "display_field": "postcode || ' - ' || \"SITE_NAME\" || ', ' || \"TOWN\""
      }
    ]
  }
}